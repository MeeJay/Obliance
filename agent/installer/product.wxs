<?xml version="1.0" encoding="utf-8"?>
<!--
  Obliance Agent - Windows MSI Installer
  Built with WiX v4+ on Windows.

  Prerequisites (one-time setup):
    dotnet tool install -g wix
    go install (Go 1.22+, https://go.dev/dl)

  Build (from agent/ directory):
    build-msi.bat

  Install command:
    msiexec /i obliance-agent.msi SERVERURL="https://..." APIKEY="your-key" /quiet
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Obliance Agent"
           Manufacturer="Obliance"
           Version="AGENT_VERSION_PLACEHOLDER"
           Language="1033"
           UpgradeCode="B5C6D7E8-F9A0-1234-BCDE-F01234567891">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Obliance Agent is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!--
      Disable the Windows Restart Manager to prevent "FilesInUse" dialogs listing
      leftover processes (e.g. ObliviewAgent / Obliview.exe from a previous installation).
      Service lifecycle is fully handled by our ServiceControl and CustomAction elements.
    -->
    <Property Id="MSIRESTARTMANAGERCONTROL" Value="Disable" />

    <!-- Properties passed via: msiexec /i ... SERVERURL="..." APIKEY="..." -->
    <Property Id="SERVERURL" Secure="yes" />
    <Property Id="APIKEY" Secure="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OblianceAgent">

        <!--
          The Go binary is a proper Windows service executable.
          It calls SetServiceStatus(SERVICE_RUNNING) via golang.org/x/sys/windows/svc,
          so the MSI Wait="yes" (default) resolves normally without hanging.
          The url and key flags are passed as service arguments; on first run the
          agent writes config.json and from then on reads that file directly.
        -->
        <Component Id="AgentExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234560001">
          <!--
            DefaultVersion forces MSI to always overwrite the exe even when the binary on disk
            has no Win32 version resource (Go binaries are unversioned by default).
            Without this, MSI may skip the copy if it finds an "unversioned but modified" file
            on disk (e.g. leftover from a failed previous install), leaving the wrong binary in place.
            65535.0.0.0 is always greater than any real version, so the source file always wins.
          -->
          <File Id="AgentExeFile" Source="dist\obliance-agent.exe" Name="obliance-agent.exe"
                DefaultVersion="65535.0.0.0" />
          <ServiceInstall Id="AgentSvc"
                          Name="OblianceAgent"
                          DisplayName="Obliance Monitoring Agent"
                          Description="Sends system metrics to the Obliance monitoring platform."
                          Start="auto"
                          Type="ownProcess"
                          Account="LocalSystem"
                          ErrorControl="normal" />
          <!--
            No Arguments here — the agent bootstraps from the registry values
            written below (HKLM\SOFTWARE\OblianceAgent) on first run, then
            persists them to config.json.  Storing the URL in service arguments
            caused http:// to be frozen in SCM across upgrades.
          -->
          <ServiceControl Id="AgentSvcStart" Name="OblianceAgent" Start="install" />
          <ServiceControl Id="AgentSvcStop"  Name="OblianceAgent" Stop="both" Remove="uninstall" Wait="yes" />
        </Component>

        <!--
          Registry fallback: agent reads these on first run if config.json is absent
          and the service arguments are not yet parsed (edge cases).
          Written to 64-bit hive via -arch x64 build flag.
        -->
        <Component Id="AgentConfig" Guid="B2C3D4E5-F6A7-8901-BCDE-EF1234560002">
          <RegistryValue Root="HKLM" Key="SOFTWARE\OblianceAgent"
                         Name="ServerUrl" Type="string" Value="[SERVERURL]" KeyPath="yes" />
          <RegistryValue Root="HKLM" Key="SOFTWARE\OblianceAgent"
                         Name="ApiKey"    Type="string" Value="[APIKEY]" />
        </Component>

        <!--
          OPTIONAL — VNC server binary for remote-access sessions.

          When the Obliance agent receives an "open_remote_tunnel" command it
          first checks whether a VNC server is already listening on port 5900.
          If not, it looks for tvnserver.exe next to obliance-agent.exe (here)
          and launches it automatically.

          HOW TO BUNDLE:
            1. Download TightVNC for Windows:  https://www.tightvnc.com/download.php
            2. Extract / install it, copy tvnserver.exe to:
                 agent\tvnserver.exe
            3. Re-build the MSI with the preprocessor variable set:
                 wix build installer\_product_versioned.wxs -b . -arch x64
                      -d TVN_SERVER_BINARY=tvnserver.exe
                      -out dist\obliance-agent.msi

          Without this flag the component is silently omitted and the MSI
          builds normally — TightVNC is then NOT deployed to managed devices.
          The agent will still attempt to use any VNC server the end-user has
          installed themselves (service auto-start or known paths).
        -->
        <?ifdef TVN_SERVER_BINARY?>
        <Component Id="TvnServer" Guid="C3D4E5F6-A7B8-9012-CDEF-012345600003">
          <File Id="TvnServerExe" Source="$(TVN_SERVER_BINARY)" Name="tvnserver.exe" />
        </Component>
        <?endif?>

      </Directory>
    </StandardDirectory>

    <Feature Id="Main">
      <ComponentRef Id="AgentExe" />
      <ComponentRef Id="AgentConfig" />
      <?ifdef TVN_SERVER_BINARY?>
      <ComponentRef Id="TvnServer" />
      <?endif?>
    </Feature>

  </Package>
</Wix>
