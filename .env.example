# ── Image version (tag Docker Hub, ex: latest, 1.0.0) ──
OBLIANCE_VERSION=latest

# ── Database ──
# If using the built-in postgres container (docker-compose.yml):
DB_PASSWORD=changeme

# If using an external PostgreSQL (docker-compose.external-db.yml):
# DATABASE_URL=postgres://obliance:yourpassword@your-db-host:5432/obliance

# ── Server ──
LISTEN_PORT=3003
NODE_ENV=production
SESSION_SECRET=change-this-to-a-random-secret

# ── Client origin (for CORS — set to your actual URL) ──
CLIENT_ORIGIN=http://localhost


# ── App name (used as prefix in notification messages) ──
APP_NAME=Obliance

# ── Default admin (created on first run) ──
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ── Monitor limits (admin policy) ──
# Minimum allowed check interval in seconds (default: 10)
# MIN_CHECK_INTERVAL=10
# Minimum allowed retry interval in seconds (default: 5)
# MIN_RETRY_INTERVAL=5

# ── Custom directory (scripts, SSH keys — persists across updates) ──
# Mounted at /custom inside the server container.
# Default: ./custom (next to your docker-compose.yml)
# Unraid example: CUSTOM_DIR=/mnt/user/appdata/obliance/custom
# CUSTOM_DIR=./custom

# ── Enable Watchtower and define the check interval to keep the containers up to date ──
#COMPOSE_PROFILES=watchtower
#WATCHTOWER_INTERVAL=3600