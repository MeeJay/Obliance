# Force LF for shell scripts (Docker entrypoints run on Linux)
*.sh text eol=lf

# Force LF for other Linux-executed files
server/docker-entrypoint.sh text eol=lf
Dockerfile text eol=lf

# Keep JSON files with LF to avoid noise in diffs
*.json text eol=lf

# Go module files and version files — LF everywhere
*.mod text eol=lf
*.sum text eol=lf
VERSION text eol=lf
